TZ=Europe/London
EXPRESS_PORT=8081

# OPC UA connector
# Set this to your OPC UA endpoint to enable the connector.
OPCUA_ENDPOINT=opc.tcp://your-opcua-host:4840

# Option A: comma-separated node ids
# Example: ns=2;s=Temperature,ns=2;s=Humidity
OPCUA_NODE_IDS=ns=2;s=Temperature,ns=2;s=Humidity

# Option B: structured node list as JSON
# OPCUA_MONITORED_NODES_JSON=[{"nodeId":"ns=2;s=Temperature","deviceId":"opcua","metric":"temperature"}]

OPCUA_SECURITY_POLICY=None
OPCUA_SECURITY_MODE=None
OPCUA_PUBLISHING_INTERVAL_MS=1000
OPCUA_SAMPLING_INTERVAL_MS=1000